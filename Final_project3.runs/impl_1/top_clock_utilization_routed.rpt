# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y0 [get_cells u_clk_wiz/u_bufg_25]
set_property LOC BUFGCTRL_X0Y16 [get_cells led_OBUF_BUFG[3]_inst]
set_property LOC BUFGCTRL_X0Y1 [get_cells clk100_IBUF_BUFG_inst]

# Location of IO Primitives which is load of clock spine
set_property LOC IOB_X0Y19 [get_cells led_OBUF[3]_inst]
set_property LOC IOB_X0Y128 [get_cells cam_xclk_OBUF_inst]

# Location of clock ports
set_property LOC IOB_X0Y126 [get_ports cam_pclk]
set_property LOC IOB_X1Y26 [get_ports clk100]

# Clock net "u_clk_wiz/clk_25mhz" driven by instance "u_clk_wiz/u_bufg_25" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_u_clk_wiz/clk_25mhz}
add_cells_to_pblock [get_pblocks  {CLKAG_u_clk_wiz/clk_25mhz}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=cam_xclk_OBUF_inst} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="u_clk_wiz/clk_25mhz"}]]]
resize_pblock [get_pblocks {CLKAG_u_clk_wiz/clk_25mhz}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "led_OBUF_BUFG[3]" driven by instance "led_OBUF_BUFG[3]_inst" located at site "BUFGCTRL_X0Y16"
#startgroup
create_pblock {CLKAG_led_OBUF_BUFG[3]}
add_cells_to_pblock [get_pblocks  {CLKAG_led_OBUF_BUFG[3]}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=led_OBUF[3]_inst} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="led_OBUF_BUFG[3]"}]]]
resize_pblock [get_pblocks {CLKAG_led_OBUF_BUFG[3]}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "clk100_IBUF_BUFG" driven by instance "clk100_IBUF_BUFG_inst" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_clk100_IBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_clk100_IBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=u_clk_wiz/u_mmcm} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clk100_IBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_clk100_IBUF_BUFG}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2}
#endgroup
